{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "types": ["node", "vite/client", "@cloudflare/workers-types"],
    "rootDirs": [".", "./.react-router/types"],
    "paths": {
      "@/*": ["./src/*"],
      "@app/*": ["./app/*"],
      "collections/*": ["./.source/*"]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "functions/**/*.ts",
    "scripts/**/*.ts",
    "source.config.ts",
    "vite.config.ts",
    "react-router.config.ts",
    ".source/**/*.ts",
    ".react-router/types/**/*"
  ],
  "exclude": ["node_modules", "src/app/**", "next-env.d.ts"]
}
