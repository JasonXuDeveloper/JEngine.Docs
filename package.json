{
  "name": "jengine.docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prebuild": "bun run favicons && bun run optimize-images",
    "build": "bun run prebuild && react-router build && bun run generate:static",
    "build:deploy": "bun run build && bun run search:sync",
    "dev": "react-router dev",
    "start": "serve ./build/client",
    "preview": "bun run build && wrangler pages dev build/client",
    "deploy": "bun run build && bun run search:sync && wrangler pages deploy build/client --project-name jengine && bun run indexnow",
    "types:check": "react-router typegen && fumadocs-mdx && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "biome check",
    "lint:links": "vite-node --config vite.scripts.config.ts ./scripts/lint-links.ts",
    "generate:static": "vite-node --config vite.scripts.config.ts ./scripts/generate-static.ts",
    "search:sync": "bun run ./scripts/sync-algolia.ts",
    "favicons": "bun run ./scripts/generate-favicons.ts",
    "optimize-images": "bun run ./scripts/optimize-images.ts",
    "indexnow": "bun run ./scripts/submit-indexnow.ts",
    "format": "biome format --write"
  },
  "dependencies": {
    "@octokit/auth-app": "^8.2.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-popover": "^1.1.15",
    "@react-router/node": "^7.14.2",
    "algoliasearch": "5.51.0",
    "class-variance-authority": "^0.7.1",
    "fumadocs-core": "16.8.2",
    "fumadocs-mdx": "14.3.1",
    "fumadocs-ui": "16.8.2",
    "lucide-react": "1.9.0",
    "octokit": "^5.0.5",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router": "^7.14.2",
    "tailwind-merge": "3.5.0",
    "zod": "^4.3.6",
    "isbot": "^5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@cloudflare/workers-types": "^4.20260425.1",
    "@react-router/dev": "^7.14.2",
    "@tailwindcss/vite": "4.2.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "postcss": "8.5.10",
    "serve": "^14.2.6",
    "sharp": "^0.34.5",
    "sharp-ico": "^0.1.5",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vite": "^8.0.10",
    "wrangler": "4.84.1"
  }
}
